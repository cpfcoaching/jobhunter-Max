# Server Environment Variables
# Do NOT commit this file to version control

# Server Configuration
PORT=3001
NODE_ENV=development

# API Keys (Secure - Never commit these to version control)
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
CLAUDE_API_KEY=
COHERE_API_KEY=

# Session Secret (Generate a random string for production)
SESSION_SECRET=your-secret-key-change-this

# CORS Configuration
FRONTEND_URL=http://localhost:5173

# Job Search — Python executable for JobSpy integration
# Use 'python' on Windows if 'python3' is not in PATH
PYTHON_EXECUTABLE=python3

# ── Integration 1: rainmanjam/jobspy-api (optional) ──────────────────────────
# When set, /api/jobs/search proxies to this external JobSpy Docker API instead
# of spawning the local Python script.  Leave blank to use the local script.
# Example: http://localhost:8000
JOBSPY_API_URL=

# ── Integration 2: ever-jobs/ever-jobs (optional) ────────────────────────────
# Self-hosted ever-jobs NestJS API URL (160+ job board aggregator).
# Required to use the "Ever-Jobs" source engine in the UI.
# Example: http://localhost:3002
EVER_JOBS_API_URL=

# ── Integration 3: Find-Me-Job AI scoring (optional) ─────────────────────────
# Jobs scoring at or above this threshold (0-100) will have a cover letter
# generated when "Score with AI" is triggered.
AI_SCORE_THRESHOLD=60
